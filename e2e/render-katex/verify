#!/usr/bin/env node
import path from 'node:path';
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { report } from '../lib/harness.mjs';

const SCENARIO_DIR = path.dirname(fileURLToPath(import.meta.url));
const resultDir = path.join(SCENARIO_DIR, 'result');

const { katexCount } = JSON.parse(readFileSync(path.join(resultDir, 'katexCount.json'), 'utf8'));
const requests = JSON.parse(readFileSync(path.join(resultDir, 'requests.json'), 'utf8'));
const external = requests.filter((u) => !u.startsWith('http://localhost:'));

if (katexCount < 2) {
  report('unexpected', `expected 2 rendered .katex nodes (inline + block), found ${katexCount}. See ${resultDir}/dom.html`);
} else if (external.length > 0) {
  report('unexpected', `katex hydration fired external requests: ${external.join(', ')}`);
} else {
  report('good', `inline and block math hydrated (${katexCount} .katex nodes), zero network requests`);
}
