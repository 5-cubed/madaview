#!/usr/bin/env node
// Verifies result/computed-styles.json, result/interaction.json, and
// result/crossCheck.json from the last `run`: every themed surface must
// actually change color across all 6 themes, no Chroma token may be left
// at the pre-fix unstyled-black regression color, clicking a theme button
// must never touch the server, the tabs-and-split-view contract (tab/pane/
// scroll state) must survive cycling through every theme via the
// ThemePicker, and the last-selected theme must survive a reload.
//
// Extended per .context/adr/20260712-233457-theme-contrast-hierarchy-fix.md:
// heading hierarchy (exact-equality + per-level 3:1 contrast), WCAG gates
// on the --tw-prose-* vars wired to theme tokens, presence checks on the
// vars wired but exempt from a WCAG gate, and distinctness checks on new
// representative .prose sub-elements.
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { readResultJSON, report } from '../lib/harness.mjs';
import { contrastRatio } from '../lib/contrast.mjs';

const SCENARIO_DIR = path.dirname(fileURLToPath(import.meta.url));
const resultDir = path.join(SCENARIO_DIR, 'result');

const styles = readResultJSON(resultDir, 'computed-styles.json');
const interaction = readResultJSON(resultDir, 'interaction.json');
const crossCheck = readResultJSON(resultDir, 'crossCheck.json');
const consoleErrors = readResultJSON(resultDir, 'consoleErrors.json');

const problems = [];
const check = (condition, message) => {
  if (!condition) problems.push(message);
};

const themeIds = Object.keys(styles);
check(themeIds.length === 6, `expected 6 themes recorded in computed-styles.json, got ${themeIds.length}`);
check(
  Object.keys(interaction).length === 6,
  `expected 6 themes recorded in interaction.json, got ${Object.keys(interaction).length}`,
);

check(consoleErrors.length === 0, `console/page errors occurred: ${JSON.stringify(consoleErrors)}`);

// The unstyled-black regression color Chroma tokens rendered as before
// this feature supplied any CSS for them.
const UNSTYLED_BLACK = 'rgb(0, 0, 0)';

const SURFACES = ['h1', 'h6', 'chromaKeyword', 'chromaString', 'tabStrip', 'sidebar', 'headerBar'];

// Representative .prose sub-elements added by the contrast-hierarchy fix
// (bold, blockquote, list item, table cell border, hr) -- read from
// styles[id].representative.*.
const REPRESENTATIVE_SURFACES = ['bold', 'blockquote', 'listItem', 'tableHeader', 'tableCellBorder', 'hr'];

// 1. Every surface's computed color must actually differ across all 6
// themes pairwise -- a surface stuck on one color across every theme is
// the "partial/inconsistent switch" failure.
for (const surface of SURFACES) {
  const values = themeIds.map((id) => styles[id][surface]);
  check(values.every((v) => v != null), `${surface}: missing computed value for one or more themes`);
  const distinct = new Set(values);
  check(
    distinct.size === themeIds.length,
    `${surface}: expected all ${themeIds.length} themes to differ, only ${distinct.size} distinct color(s) seen (${JSON.stringify(values)})`,
  );
}

// 1b. Same distinctness bar for the new representative .prose sub-elements.
for (const surface of REPRESENTATIVE_SURFACES) {
  const values = themeIds.map((id) => styles[id].representative?.[surface]);
  check(values.every((v) => v != null), `representative.${surface}: missing computed value for one or more themes`);
  const distinct = new Set(values);
  check(
    distinct.size === themeIds.length,
    `representative.${surface}: expected all ${themeIds.length} themes to differ, only ${distinct.size} distinct color(s) seen (${JSON.stringify(values)})`,
  );
}

// Settings' own themed surface (read during the interaction pass) must
// also differ across all 6 themes.
const settingsValues = themeIds.map((id) => interaction[id].settingsColor);
check(settingsValues.every((v) => v != null), 'settings: missing computed border color for one or more themes');
check(
  new Set(settingsValues).size === themeIds.length,
  `settings: expected all ${themeIds.length} themes to differ, only ${new Set(settingsValues).size} distinct color(s) seen (${JSON.stringify(settingsValues)})`,
);

// 2. No keyword/string Chroma token may ever equal the unstyled-black
// regression color.
for (const id of themeIds) {
  check(styles[id].chromaKeyword !== UNSTYLED_BLACK, `${id}: chroma keyword token still renders unstyled black`);
  check(styles[id].chromaString !== UNSTYLED_BLACK, `${id}: chroma string token still renders unstyled black`);
}

// 3. The preview swatch reflected the hovered theme before commit, and
// both the committed data-theme attribute and localStorage matched the
// clicked theme immediately after commit (no round-trip needed).
for (const id of Object.keys(interaction)) {
  const rec = interaction[id];
  check(rec.previewSwatchTheme === id, `${id}: preview swatch did not show the hovered theme before commit`);
  check(rec.committedAttr === id, `${id}: document.documentElement data-theme did not match the clicked theme`);
  check(rec.storedTheme === id, `${id}: localStorage theme did not match the clicked theme`);
}

// 4. Zero network delta: clicking a theme button must never fire an
// /api/* call, for any of the 6 themes.
for (const id of Object.keys(interaction)) {
  check(interaction[id].apiRequestDelta === 0, `${id}: clicking this theme fired ${interaction[id].apiRequestDelta} /api/* request(s)`);
}

// 5. Tabs-and-split-view cross-check: pane/tab/scroll state opened before
// cycling themes (while staying on /view/*, no Settings round trip) must
// be byte-identical after cycling through all 6, and cycling themes this
// way must fire zero additional /api/* requests either.
check(
  JSON.stringify(crossCheck.beforeSwitching) === JSON.stringify(crossCheck.afterSwitching),
  `tab/pane/scroll state changed after cycling themes: before=${JSON.stringify(crossCheck.beforeSwitching)} after=${JSON.stringify(crossCheck.afterSwitching)}`,
);
check(crossCheck.beforeSwitching.scrollTop > 0, 'test setup issue: scrollTop was not actually moved before switching');
check(
  crossCheck.apiRequestsAfterThemeLoop === crossCheck.apiRequestsBeforeThemeLoop,
  `cycling themes while on /view/* fired ${crossCheck.apiRequestsAfterThemeLoop - crossCheck.apiRequestsBeforeThemeLoop} /api/* request(s)`,
);

// 6. Persistence: the last-selected theme survives a reload.
check(
  crossCheck.afterReload.dataTheme === crossCheck.lastTheme,
  `reload did not preserve the applied data-theme (expected ${crossCheck.lastTheme}, got ${crossCheck.afterReload.dataTheme})`,
);
check(
  crossCheck.afterReload.storedTheme === crossCheck.lastTheme,
  `reload did not preserve localStorage theme (expected ${crossCheck.lastTheme}, got ${crossCheck.afterReload.storedTheme})`,
);

// --- Contrast-hierarchy fix checks (see
// .context/adr/20260712-233457-theme-contrast-hierarchy-fix.md) ---

const HEADING_LEVELS = ['h1', 'h2', 'h3', 'h4', 'h5', 'h6'];
const TEXT_VARS = ['body', 'headings', 'bold', 'quotes', 'captions', 'code', 'pre-code'];
const MARKER_VARS = ['bullets', 'counters'];
const PRESENCE_ONLY_VARS = ['hr', 'quote-borders', 'th-borders', 'td-borders', 'pre-bg'];

// 7. Heading hierarchy: per theme, h1..h6 and --text must be 6+1
// pairwise-distinct values, and each heading level must independently
// clear 3:1 contrast against that theme's --bg.
for (const id of themeIds) {
  const { headings, resolvedText, resolvedBg } = styles[id];
  check(headings != null && resolvedText != null && resolvedBg != null, `${id}: missing headings/--text/--bg resolved values`);
  if (!headings || !resolvedText || !resolvedBg) continue;

  const allValues = [...HEADING_LEVELS.map((level) => headings[level]), resolvedText];
  const distinct = new Set(allValues);
  check(
    distinct.size === allValues.length,
    `${id}: heading hierarchy has a color collision -- h1..h6/--text are not all distinct (${JSON.stringify({ ...headings, text: resolvedText })})`,
  );

  for (const level of HEADING_LEVELS) {
    const ratio = contrastRatio(headings[level], resolvedBg);
    check(ratio >= 3, `${id}: ${level} (${headings[level]}) contrast ${ratio.toFixed(2)}:1 against --bg (${resolvedBg}) is below the 3:1 bar`);
  }
}

// 8. WCAG text-var gate: body/bold/quotes/captions/code/pre-code must
// clear 4.5:1 against --bg in every theme.
for (const id of themeIds) {
  const { proseVars, resolvedBg } = styles[id];
  for (const varName of TEXT_VARS) {
    const value = proseVars?.[varName];
    check(value != null && value !== '', `${id}: --tw-prose-${varName} did not resolve to a value`);
    if (!value) continue;
    const ratio = contrastRatio(value, resolvedBg);
    check(ratio >= 4.5, `${id}: --tw-prose-${varName} (${value}) contrast ${ratio.toFixed(2)}:1 against --bg is below the 4.5:1 bar`);
  }
}

// 9. WCAG marker-var gate: bullets/counters must clear 3:1 against --bg in
// every theme.
for (const id of themeIds) {
  const { proseVars, resolvedBg } = styles[id];
  for (const varName of MARKER_VARS) {
    const value = proseVars?.[varName];
    check(value != null && value !== '', `${id}: --tw-prose-${varName} did not resolve to a value`);
    if (!value) continue;
    const ratio = contrastRatio(value, resolvedBg);
    check(ratio >= 3, `${id}: --tw-prose-${varName} (${value}) contrast ${ratio.toFixed(2)}:1 against --bg is below the 3:1 bar`);
  }
}

// 10. Presence-only check: hr/quote-borders/th-borders/td-borders/pre-bg
// must be wired (non-null, non-empty) in every theme -- no WCAG ratio
// gate, since these are hairlines/backgrounds, not rendered text.
for (const id of themeIds) {
  const { proseVars } = styles[id];
  for (const varName of PRESENCE_ONLY_VARS) {
    const value = proseVars?.[varName];
    check(value != null && value !== '', `${id}: --tw-prose-${varName} did not resolve to a value`);
  }
}

if (problems.length > 0) {
  report('unexpected', `${problems.length} check(s) failed:\n- ${problems.join('\n- ')}`);
} else {
  report(
    'good',
    'all theme-switching checks passed: 13 distinct-per-theme surfaces (including Settings and the new .prose sub-elements), no unstyled Chroma tokens, zero network delta per click, tab/scroll state preserved across cycling, theme persists across reload, heading hierarchy has no color collisions and clears 3:1 in every theme, WCAG text/marker vars clear their bars in every theme, hairline/background vars are wired in every theme',
  );
}
