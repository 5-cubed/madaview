#!/usr/bin/env node
// Scenario: render-gfm-basics
// Starts madaview against this scenario's fixture root, navigates to the
// fixture file in a real browser, and captures the rendered DOM + server
// logs + metadata to result/ for `verify` to check.
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { resetResultDir, startServer, nextPort, writeMetadata, writeText } from '../lib/harness.mjs';
import { withPage } from '../lib/browser.mjs';

const SCENARIO_DIR = path.dirname(fileURLToPath(import.meta.url));

async function main() {
  const resultDir = await resetResultDir(SCENARIO_DIR);
  const root = path.join(SCENARIO_DIR, 'data');
  const port = nextPort();

  const server = await startServer({ root, port });
  try {
    await withPage(async (page, requests) => {
      await page.goto(`http://localhost:${port}/view/fixture.md`);
      await page.waitForSelector('article');
      const dom = await page.locator('article').innerHTML();
      await writeText(resultDir, 'dom.html', dom);
      await writeText(resultDir, 'requests.json', JSON.stringify(requests, null, 2));
    });
  } finally {
    await writeText(resultDir, 'server.log', server.getLogs());
    await server.stop();
  }

  await writeMetadata(resultDir, { scenario: 'render-gfm-basics', root, port });
  console.log(`run complete: ${resultDir}`);
}

main().catch((err) => {
  console.error(err);
  process.exit(1);
});
