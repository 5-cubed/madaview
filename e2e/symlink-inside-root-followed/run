#!/usr/bin/env node
// Scenario: symlink-inside-root-followed
// A symlink physically under the fixture root, pointing to a target
// outside root, must still serve its target's content successfully (the
// ADR's symlink policy: the root owner's placement of the symlink is
// itself the boundary decision).
//
// The symlink is created here at run time rather than checked into git, to
// avoid symlink portability issues across checkouts/platforms.
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { symlink, rm, mkdir } from 'node:fs/promises';
import { resetResultDir, startServer, nextPort, writeMetadata, writeJSON, writeText } from '../lib/harness.mjs';

const SCENARIO_DIR = path.dirname(fileURLToPath(import.meta.url));

async function main() {
  const resultDir = await resetResultDir(SCENARIO_DIR);
  const root = path.join(SCENARIO_DIR, 'data', 'root');
  const linkPath = path.join(root, 'linked.md');
  const target = path.join(SCENARIO_DIR, 'data', 'outside', 'secret.md');

  await mkdir(root, { recursive: true });
  await rm(linkPath, { force: true });
  await symlink(target, linkPath);

  const port = nextPort();
  const server = await startServer({ root, port });
  let apiResult;
  try {
    const res = await fetch(`http://localhost:${port}/api/file?path=linked.md`);
    apiResult = { status: res.status, body: await res.text() };
  } finally {
    await writeText(resultDir, 'server.log', server.getLogs());
    await server.stop();
  }

  await writeJSON(resultDir, 'result.json', apiResult);
  await writeMetadata(resultDir, { scenario: 'symlink-inside-root-followed', root, port });
  console.log(`run complete: ${resultDir}`);
}

main().catch((err) => {
  console.error(err);
  process.exit(1);
});
