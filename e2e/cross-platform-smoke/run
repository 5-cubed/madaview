#!/usr/bin/env node
// Scenario: cross-platform-smoke
// Build, launch the binary, curl /api/status, expect HTTP 200 with valid
// JSON — run on each release runner's native OS/arch (windows-latest,
// macos-latest, ubuntu-latest). Deliberately avoids `make`/npm: this
// scenario only proves the compiled binary starts and answers on its
// native OS, not the full UI, and `make` isn't guaranteed present on
// Windows runners.
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { spawn } from 'node:child_process';
import { mkdir } from 'node:fs/promises';
import { REPO_ROOT, resetResultDir, nextPort, writeMetadata, writeJSON, writeText } from '../lib/harness.mjs';

const SCENARIO_DIR = path.dirname(fileURLToPath(import.meta.url));
const BIN_NAME = process.platform === 'win32' ? 'madaview-smoke.exe' : 'madaview-smoke';

function run(cmd, args, opts) {
  return new Promise((resolve, reject) => {
    const child = spawn(cmd, args, { stdio: 'inherit', ...opts });
    child.on('error', reject);
    child.on('exit', (code) => (code === 0 ? resolve() : reject(new Error(`${cmd} exited ${code}`))));
  });
}

async function main() {
  const resultDir = await resetResultDir(SCENARIO_DIR);
  const binDir = path.join(resultDir, 'bin');
  await mkdir(binDir, { recursive: true });
  const binPath = path.join(binDir, BIN_NAME);

  await run('go', ['build', '-o', binPath, './cmd/madaview'], { cwd: REPO_ROOT });

  const root = path.join(SCENARIO_DIR, 'data');
  const port = nextPort();
  const logs = [];
  const child = spawn(binPath, ['--root', root, '--port', String(port)]);
  child.stdout.on('data', (d) => logs.push(d.toString()));
  child.stderr.on('data', (d) => logs.push(d.toString()));

  let status = null;
  let error = null;
  try {
    await waitForReady(port);
    const res = await fetch(`http://localhost:${port}/api/status`);
    status = { httpStatus: res.status, body: await res.json() };
  } catch (err) {
    error = String(err);
  } finally {
    await writeText(resultDir, 'server.log', logs.join(''));
    child.kill();
  }

  await writeJSON(resultDir, 'result.json', { status, error });
  await writeMetadata(resultDir, { scenario: 'cross-platform-smoke', root, port, binPath });
  console.log(`run complete: ${resultDir}`);
}

async function waitForReady(port, timeoutMs = 8000) {
  const start = Date.now();
  while (Date.now() - start < timeoutMs) {
    try {
      const res = await fetch(`http://localhost:${port}/api/status`);
      if (res.ok) return;
    } catch {
      // not up yet
    }
    await new Promise((r) => setTimeout(r, 100));
  }
  throw new Error(`server did not become ready on port ${port} within ${timeoutMs}ms`);
}

main().catch((err) => {
  console.error(err);
  process.exit(1);
});
